---
import { SITE } from "../lib/site-data";

const { currentPath = "/" } = Astro.props;

const navItems = [
  { href: "/logs/", label: "个人日志" },
  { href: "/product-logs/", label: "产品日志" },
  { href: "/archive/", label: "归档" },
  { href: "/tags/", label: "标签" },
];

const isActive = (href: string) => currentPath === href || (href !== "/" && currentPath.startsWith(href));
---

<header class="site-header">
  <div class="container">
    <nav class="nav" aria-label="主导航">
      <a class="brand" href="/">{SITE.name}</a>
      <div class="nav-links">
        {navItems.map((item) => (
          <a class="nav-link" href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))}
      </div>
      <div class="nav-actions">
        <a class="search-link" href="/search/" aria-label="搜索">
          <svg aria-hidden="true" width="19" height="19" viewBox="0 0 24 24" fill="none">
            <path d="m21 21-4.2-4.2m1.2-5.3a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <span>搜索</span>
        </a>
        <a class="github-link" href={SITE.github} target="_blank" rel="noreferrer">
          <svg aria-hidden="true" width="23" height="23" viewBox="0 0 24 24" fill="currentColor">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49v-1.9c-2.78.62-3.37-1.22-3.37-1.22-.45-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.35 1.11 2.92.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 7c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.04.36.32.68.94.68 1.9v2.8c0 .27.18.59.69.49A10.16 10.16 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z" />
          </svg>
          <span>GitHub</span>
        </a>
        <button class="theme-toggle" type="button" aria-label="切换明暗主题" data-theme-toggle>
          <svg aria-hidden="true" width="23" height="23" viewBox="0 0 24 24" fill="none">
            <path d="M12 3v2.2M12 18.8V21M3 12h2.2M18.8 12H21M5.64 5.64l1.56 1.56M16.8 16.8l1.56 1.56M18.36 5.64 16.8 7.2M7.2 16.8l-1.56 1.56M16.5 12a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>
