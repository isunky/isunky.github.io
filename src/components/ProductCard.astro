---
import { formatDate, getProductHref } from "../lib/site-data";

const { product } = Astro.props as { product: any };
const latest = product.latestUpdate;
---

<article class="product-card">
  <div class="product-card__top">
    <h3><a href={getProductHref(product)}>{product.data.name}</a></h3>
    <span class="status">{product.data.status}</span>
  </div>
  <p>{product.data.description}</p>
  <div class="stack" aria-label={`${product.data.name} 技术栈`}>
    {product.data.stack.map((item: string) => <span>{item}</span>)}
  </div>
  <div class="latest-update">
    {latest ? (
      <>
        <small>{latest.stage} · {formatDate(latest.date)}</small>
        <a href={latest.href}>{latest.title} →</a>
      </>
    ) : (
      <>
        <small>暂无公开动态</small>
        <a href={getProductHref(product)}>查看产品介绍 →</a>
      </>
    )}
  </div>
  <div class="card-actions">
    <a class="text-link" href={getProductHref(product)}>介绍 →</a>
    <a class="text-link" href={product.data.repo} target="_blank" rel="noreferrer">仓库 →</a>
  </div>
</article>
