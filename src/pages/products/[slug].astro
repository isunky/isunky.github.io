---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryList from "../../components/EntryList.astro";
import HomeRail from "../../components/HomeRail.astro";
import {
  getFeaturedProducts,
  getLatestProductActivity,
  getPublishedEntries,
  sortByDateDesc,
} from "../../lib/site-data";

export async function getStaticPaths() {
  const products = getPublishedEntries(await getCollection("products"));
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await product.render();
const products = await getCollection("products");
const productLogs = await getCollection("product-logs");
const logs = await getCollection("logs");
const [featuredProduct] = getFeaturedProducts([product], productLogs, 1);
const relatedLogs = sortByDateDesc(getPublishedEntries(productLogs)).filter((entry) => entry.data.product === product.slug);
const activity = getLatestProductActivity(productLogs, products, 6);
---

<BaseLayout title={`${product.data.name} - isunky`} description={product.data.description}>
  <main class="container page-grid">
    <article class="main-column article">
      <header class="article-header">
        <div class="entry-meta">
          <span>产品</span>
          <span>{product.data.status}</span>
        </div>
        <h1>{product.data.name}</h1>
        <p>{product.data.description}</p>
        <div class="stack">
          {product.data.stack.map((item) => <span>{item}</span>)}
        </div>
        <div class="action-row">
          <a class="button primary" href={product.data.repo} target="_blank" rel="noreferrer">查看仓库</a>
          {product.data.site && <a class="button secondary" href={product.data.site} target="_blank" rel="noreferrer">访问站点</a>}
        </div>
      </header>
      <div class="article-body">
        <Content />
      </div>

      <section class="section">
        <div class="section-header">
          <h2>产品动态</h2>
          {featuredProduct.latestUpdate && <a class="text-link" href={featuredProduct.latestUpdate.href}>最新：{featuredProduct.latestUpdate.title} →</a>}
        </div>
        <EntryList entries={relatedLogs} type="product-logs" products={products} />
      </section>
    </article>
    <HomeRail activity={activity} logs={logs} productLogs={productLogs} />
  </main>
</BaseLayout>
