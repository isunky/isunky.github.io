---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryList from "../../components/EntryList.astro";
import HomeRail from "../../components/HomeRail.astro";
import { getLatestProductActivity, getPublishedEntries, sortByDateDesc } from "../../lib/site-data";

const logs = sortByDateDesc(getPublishedEntries(await getCollection("logs")));
const products = await getCollection("products");
const productLogs = await getCollection("product-logs");
const activity = getLatestProductActivity(productLogs, products, 6);
---

<BaseLayout title="个人日志 - isunky" description="isunky 的个人日志、思考和阶段性复盘。">
  <main class="container page-grid">
    <div class="main-column">
      <section class="hero">
        <h1>个人日志</h1>
        <p>记录思考、实践方法和阶段性复盘。产品相关内容会进入独立的产品日志。</p>
      </section>
      <EntryList entries={logs} />
    </div>
    <HomeRail activity={activity} logs={logs} productLogs={productLogs} />
  </main>
</BaseLayout>
